output_type: generate_until
doc_to_visual: !function utils.game_qa_doc_to_visual
doc_to_text: !function utils.game_qa_doc_to_text
doc_to_target: "answer"

process_results: !function utils.game_qa_process_results

metric_list:
  - metric: game_qa_acc
    aggregation: !function utils.game_qa_aggregate_results
    higher_is_better: true

generation_kwargs:
  max_new_tokens: 1024

lmms_eval_specific_kwargs:
  default:
    pre_prompt: "Answer with the option letter or number only.\n"
    post_prompt: ""
